# Subfolder inside notebook/ where your Notion pages will be stored.
# Pages end up at: notebook/<PAGES_DIR>/
# Run: cp .env.example .env  and set your own name.
PAGES_DIR=your-name

# Weather defaults
WEATHER_PAGE=Daily Notes
WEATHER_CITY=Stuttgart
WEATHER_LAT=48.78
WEATHER_LON=9.18
WEATHER_TZ=Europe/Berlin
